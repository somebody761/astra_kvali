Разбиение нормального распределения на бинсы и счет плотности вероятности в них:
import numpy as np

# 1. Генерируем данные (например, координаты или яркости 10 000 звёзд)
# mu - среднее значение, sigma - стандартное отклонение
mu, sigma = 0, 1
num_stars = 10000
stars_data = np.random.normal(mu, sigma, num_stars)

# 2. Задаем границы столбиков (бинов)
# Создаем 20 столбиков в диапазоне от -4 до 4
bins = np.linspace(-4, 4, 21) 

# 3. Считаем количество звёзд в столбиках и плотность вероятности
# counts - массив с абсолютным количеством звёзд в каждом столбике
counts, _ = np.histogram(stars_data, bins=bins)

# density_array - массив значений плотности вероятности для каждого столбика
density_array, _ = np.histogram(stars_data, bins=bins, density=True)

# --- Вывод результатов ---
print("Границы столбиков:\n", np.round(bins, 2))
print("\nКол-во звёзд в столбиках:\n", counts)
print("\nПлотность вероятности для каждого столбика:\n", np.round(density_array, 3))








