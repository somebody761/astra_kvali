Минимизация пример кода:
import numpy as np
import matplotlib.pyplot as plt
import scipy as sp
from scipy.optimize import minimize
x = np.array([...])
y = np.array([...])
def objective(params, x1, y1):
    a, b = params
    model = a*x1 + b
    return np.sum(np.abs(model - y)) # Минимизируем MAE
x_ls1 = np.linspace(np.min(x), np.max(x), 50)
x0 = [2, 0.5] #оценочные значения коэфициентов
res = minimize(objective, x0, args=(x, y), method='Nelder-Mead')

print("Оптимальные параметры:", res.x)
plt.plot(x_ls1, res.x[0] * x_ls1 + res.x[0], label='module')






Оптимизация пример кода:
import numpy as np
import matplotlib.pyplot as plt
import scipy as sp
x_data = np.array([1, 2, 3, 4, 5, 6, 7])
y_data = np.array([4.02, 6.89, 10, 20, 15.94, 19.08, 22.23])

def approximation(x, alpha, beta):
    return alpha*x + beta

(alpha, beta), _ = sp.optimize.curve_fit(approximation, x_data, y_data, p0=[3, -6])

xh = np.linspace(np.min(x_data), np.max(x_data), 50)
fig, ax = plt.subplots(figsize=(8, 8), layout="tight")
plt.plot(x_data, y_data, marker='.', ls=' ')
ax.plot(xh, approximation(xh, alpha, beta), color="green", label="Аппроксимация")
ax.legend()

print(f"""
Найденные параметры: 
{alpha = :.3f},
{beta = :.3f},
""")








